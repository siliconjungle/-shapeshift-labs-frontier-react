{
  "name": "frontier-collab-markdown-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A serious end-to-end Frontier collaboration demo with React, CodeMirror, CRDT sync, WebSocket transport, persistence, presence, and latency telemetry.",
  "scripts": {
    "dev:server": "node server/index.mjs",
    "dev:client": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "start": "node server/index.mjs",
    "test": "node test/smoke.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@shapeshift-labs/frontier-crdt": "^0.1.2",
    "@shapeshift-labs/frontier-crdt-sync": "^0.1.4",
    "@shapeshift-labs/frontier-crdt-websocket": "^0.1.4",
    "@shapeshift-labs/frontier-react": "file:../..",
    "@shapeshift-labs/frontier-richtext": "^0.1.0",
    "codemirror": "^6.0.2",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.2.4"
  }
}
